{
  "name": "obsidian-checkbox-context-menu",
  "version": "1.0.0",
  "description": "Right-click context menu to toggle checkbox states in Obsidian",
  "main": "main.js",
  "scripts": {
    "build": "tsc -b && node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "markdown",
    "checkbox"
  ],
  "license": "MIT",
  "devDependencies": {
    "@codemirror/state": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@types/codemirror": "^5.60.7",
    "esbuild": "^0.28.1",
    "obsidian": "^1.13.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.10"
  }
}
