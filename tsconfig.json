{
  "compilerOptions": {
    "baseUrl": ".",
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "allowJs": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": false,
    "typeRoots": ["./node_modules/@types"],
    "strict": false,
"lib": ["ES2016", "DOM"],
     "noEmit": true,
     "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
